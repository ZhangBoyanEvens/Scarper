# DeepSeek
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Clerk（用户登录）https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# JWT issuer（Clerk 控制台 → API Keys → Issuer，须与前端实例一致）
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
# 若在 Clerk 创建了 JWT Template，前端填同名（可选）
# VITE_CLERK_JWT_TEMPLATE=

# 前端 Vite 代理目标
VITE_BACKEND_URL=http://127.0.0.1:8000

# 爬虫（可选）
# ALLOW_LOCALHOST=false
# CACHE_TTL_SEC=300
# Render 部署建议 false（无法安装 Playwright 系统依赖）
# PLAYWRIGHT_ENABLED=false
# PLAYWRIGHT_MAX_RETRIES=3
# PLAYWRIGHT_CONTEXT_POOL_SIZE=2
# PLAYWRIGHT_PERSISTENT_CONTEXT=true
# PLAYWRIGHT_BLOCK_IMAGES=true
# PLAYWRIGHT_STEALTH_ENABLED=true
# 全流程超时（秒），超时返回错误结果而非一直卡住
# EXTRACT_TIMEOUT_SEC=90
# PLAYWRIGHT_TOTAL_TIMEOUT_SEC=45
# AI_SUMMARIZE_TIMEOUT_SEC=55

# Neon Postgres：每个 Clerk 账户独立目录 u_<user_id>，每项目独立库 u_<user_id>_p_<id>
# NEON_ENABLED=true
# NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# NEON_REQUIRE_AUTH=true
# NEON_DEV_USER_ID=local-dev
# 每用户 Neon 数据总配额（MB，含各项目上传与 Dashboard 正文）
# NEON_USER_QUOTA_MB=200
# 前端：Neon 可用时优先走后端上传（须登录传 JWT；否则 localStorage）
# VITE_NEON_UPLOAD_ENABLED=true

# 规则解析失败时用 AI 从 HTML 恢复正文（需 DEEPSEEK_API_KEY）
# AI_CRAWL_RECOVERY_ENABLED=true
# AI_RECOVERY_HTML_CHARS=16000
# 失败时 AI 诊断环节与原因
# AI_FAILURE_DIAGNOSIS_ENABLED=true
