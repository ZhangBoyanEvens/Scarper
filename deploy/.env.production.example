# 复制到项目根目录 .env（与 docker-compose 同级）
# cp deploy/.env.production.example .env

# ========== DeepSeek ==========
DEEPSEEK_API_KEY=sk-your-key
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ========== Clerk（前后端都要配）==========
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
# VITE_CLERK_JWT_TEMPLATE=

# 内测建议开启
CLERK_REQUIRE_AUTH=true
DAILY_EXTRACT_LIMIT=20

# ========== Neon ==========
NEON_ENABLED=true
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
NEON_REQUIRE_AUTH=true
VITE_NEON_UPLOAD_ENABLED=true
NEON_USER_QUOTA_MB=200

# ========== 香港 VPS 生产（Nginx 同域反代，前端 VITE_BACKEND_URL 留空）==========
# 若有域名，填 https://你的域名（逗号分隔多个）
CORS_ORIGINS=http://你的公网IP,https://你的域名

# ========== Playwright（香港 2GB 推荐）==========
PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_CONTEXT_POOL_SIZE=1
PLAYWRIGHT_STEALTH_ENABLED=true
PLAYWRIGHT_BLOCK_IMAGES=true
EXTRACT_TIMEOUT_SEC=90
