FROM node:22-alpine AS builder

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY index.html vite.config.ts tsconfig*.json ./
COPY public ./public
COPY src ./src

# 生产：前后端同域，留空 VITE_BACKEND_URL，由 Nginx 反代 /api
ARG VITE_CLERK_PUBLISHABLE_KEY
ARG VITE_NEON_UPLOAD_ENABLED=true
ARG VITE_CLERK_JWT_TEMPLATE=
ARG VITE_DEEPSEEK_MODEL=deepseek-chat

ENV VITE_BACKEND_URL= \
    VITE_CLERK_PUBLISHABLE_KEY=$VITE_CLERK_PUBLISHABLE_KEY \
    VITE_NEON_UPLOAD_ENABLED=$VITE_NEON_UPLOAD_ENABLED \
    VITE_CLERK_JWT_TEMPLATE=$VITE_CLERK_JWT_TEMPLATE \
    VITE_DEEPSEEK_MODEL=$VITE_DEEPSEEK_MODEL

RUN npm run build

FROM nginx:1.27-alpine

COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80
